#!/bin/bash

do_backup() {
  clear
  echo "Copia de seguridad..."
  cd /root/DTunnel
  #rm -r painelbackup > /dev/null
  #mkdir painelbackup > /dev/null
  cp prisma/database.db painelbackup
  cp .env painelbackup
  zip -r painelbackup.zip painelbackup
  mv painelbackup.zip /root
  echo
  echo "panelbackup.zip guardado en /root"
  echo
  exit 0
}

toggle_auto_backup() {
  clear
  read -p "DESEA HABILITAR LA COPIA DE SEGURIDAD AUTOMГЃTICA? (s/n) " atb
  [[ $atb = @(s|S) ]] && {
    echo "Ativando...."
    backmod
    echo
    echo "Copia de seguridad activa de 5 en 5 horas!"
    exit 0
  }
  menudt
}

remove_panel() {
  clear
  read -p "DESEA ELIMINAR EL PANEL? (s/n) " rev
  [[ $rev = @(s|S) ]] && {
    echo "EliminaciГіn..."
    poff
    rm /bin/pon /bin/poff /bin/menudt /bin/backmod
    rm -r /root/DTunnel
    echo "Eliminado con Г©xito!"
    exit 0
  }
  menudt
}

restore_backup() {
  clear
  [[ ! -e /root/painelbackup.zip ]] && {
    echo "Archivo panelbackup.zip no encontrado en /root"
    sleep 4
    menudt
  }
  read -p "DESEA RESTAURAR LA COPIA DE SEGURIDAD? (s/n) " rapi
  [[ $rapi = @(s|S) ]] && {
    echo "Restaurando..."
    cd /root/DTunnel
    rm prisma/database.db
    rm .env
    cd /root
    unzip painelbackup.zip
    cd painelbackup
    mv database.db ../DTunnel/prisma
    mv .env ../DTunnel
    cd /root
    rm -r painelbackup
    pon
    echo
    echo "Copia de seguridad restaurada con Г©xito!"
    exit 0
  }
  [[ $rapi = @(n|N) ]] && {
    echo "Volviendo a menudt"
    sleep 2
    menudt
  }
  menudt
}
